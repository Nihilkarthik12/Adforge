      "type": "text",
      "x": 80, "y": 1168, "width": 380, "height": 50, "rotation": 0,
      "content": "Book a demo",
      "fontFamily": "var(--font-inter), Arial, sans-serif",
      "fontSize": 32,
      "fontWeight": 600,
      "color": "#FFFFFF",
      "textAlign": "center",
      "lineHeight": 1.2,
      "editable": true,
      "bindsTo": "cta"
